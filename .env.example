# ==================== Telegram Bot ====================
# Токен бота от @BotFather
BOT_TOKEN=

# Telegram ID администратора 
ADMIN_IDS=[123456789,123456789]

# Режим работы: all = для всех, admin = только для администратора
BOT_MODE=all

VPN_HOST=domain.ru

# ==================== Amnezia API ====================
# Адрес API (http://IP:PORT)
AMNEZIA_API_URL=http://localhost:4001

# Ключ API из .env amnezia-api (FASTIFY_API_KEY)
AMNEZIA_API_KEY=

# amneziawg2 или xray
AMNEZIA_PROTOCOL=amneziawg2

# ==================== База данных ====================
# Путь к SQLite базе данных
DB_PATH=./awg.db

DB_ENCRYPTION_KEY=

# ==================== Mini App =======================

# Хост и порт Flask-сервера Mini App
MINIAPP_HOST=0.0.0.0
MINIAPP_PORT=2749

# Режим разработки: True = отключает проверку подписи Telegram initData
# Обычный режим: False = включает проверку подписи Telegram initData
MINIAPP_DEV_MODE=False
